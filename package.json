{
  "name": "sub-wave",
  "version": "0.1.18",
  "private": true,
  "description": "SUB/WAVE — personal internet radio station. One Icecast stream, AI DJ, AI-curated playlists.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "subwave": "bin/subwave"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node bin/subwave",
    "setup": "node bin/subwave setup",
    "dev": "node bin/subwave setup",
    "dev:docker": "COMPOSE_FILE=docker/docker-compose.yml docker compose up -d",
    "dev:web": "npm --prefix web run dev",
    "rebuild": "COMPOSE_FILE=docker/docker-compose.yml docker compose up -d --build",
    "logs": "COMPOSE_FILE=docker/docker-compose.yml docker compose logs -f",
    "down": "COMPOSE_FILE=docker/docker-compose.yml docker compose down",
    "jingles": "COMPOSE_FILE=docker/docker-compose.yml bash scripts/generate-jingles.sh",
    "tui": "npm --prefix tui start",
    "cli:typecheck": "npm --prefix cli run typecheck",
    "tui:typecheck": "npm --prefix tui run typecheck"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "picocolors": "^1.1.1",
    "tsx": "^4.19.2"
  }
}
