# Production defaults are same-origin (/stream.mp3 and /api) — Caddy routes
# both to the right backend. Only override these for local dev where you're
# running the controller/icecast on different ports.

# NEXT_PUBLIC_STREAM_URL=http://localhost:7702/stream.mp3
# NEXT_PUBLIC_API_URL=http://localhost:7701

# Public origin of the deployed site. Used to build absolute URLs for the
# Open Graph / Twitter share cards, canonical links, robots.txt, and the
# sitemap. In production set it in docker/.env — compose passes it to the web
# service as both a build arg and a runtime env var. For local dev it is
# unset and everything falls back to the localhost origin, which is correct.
# SITE_URL=https://radio.example.com

# What renders at /. `landing` shows the marketing broadsheet with the live
# player embedded inline. `player` shows the existing fullscreen listener UI.
# Default: player. Set to `landing` on the public marketing host
# (e.g. radio.example.com). /listen always serves the player; /landing always
# serves the landing, regardless of this flag.
SUBWAVE_HOMEPAGE=player
