# Navidrome (Subsonic API)
NAVIDROME_URL=http://localhost:4533
NAVIDROME_USER=user
NAVIDROME_PASS=changeme

# If the controller can read your music files directly from disk,
# set this to the mount path. Much more efficient than streaming over HTTP.
# MUSIC_LIBRARY_PATH=/music

# ── LLM ───────────────────────────────────────────────────────────────────
# The ACTIVE provider/model is chosen at runtime in the admin Settings UI
# (persisted to state/settings.json) — not here. These vars are only:
#   - Ollama defaults (the homelab provider)
#   - cloud API keys, auto-read by the AI SDK when the Settings UI leaves
#     the key field blank.

# Ollama — homelab default provider (no API key needed).
# Both the server URL and the model are set in the admin Settings UI
# (LLM provider tab), not here.

# Cloud providers — leave blank unless you switch to them in Settings.
# The AI SDK reads these automatically when the Settings key field is empty.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=
# AI_GATEWAY_API_KEY=    # one key; switch provider just by changing the model id
# ELEVENLABS_API_KEY=    # only for the 'cloud' TTS engine via ElevenLabs

# Piper TTS — paths inside the container
PIPER_BIN=/usr/local/bin/piper
PIPER_VOICE=/opt/piper/voices/en_GB-alan-medium.onnx
PIPER_VOICE_CONFIG=/opt/piper/voices/en_GB-alan-medium.onnx.json

# ── Speech rate ───────────────────────────────────────────────────────────
# Speed multiplier for the AI DJ's voice: 1.0 = normal, lower = slower
# (e.g. 0.85 ≈ 15% slower), higher = faster. TTS_SPEED is the default for
# every engine; the per-engine vars override it when set. ElevenLabs only
# accepts 0.7–1.2 — out-of-range values are clamped.
TTS_SPEED=0.85
# PIPER_SPEED=0.85
# KOKORO_SPEED=0.85
# CLOUD_TTS_SPEED=0.85

# Icecast — must match docker-compose
ICECAST_SOURCE_PASSWORD=changeme

# Liquidsoap telnet — only override when running the controller OUTSIDE the
# docker-compose network (e.g. `npm run dev` natively while liquidsoap stays
# in docker). The dev compose binds 127.0.0.1:1234 for this case. When the
# controller runs inside compose, leave this unset — the default 'liquidsoap'
# service hostname resolves over the compose network.
# LIQUIDSOAP_HOST=localhost
# LIQUIDSOAP_PORT=1234

# Server
PORT=7701

# How often the fallback auto-playlist (state/auto.m3u) is rebuilt.
# Each refresh calls Navidrome's getStarred2 + getRandomSongs. 60 min is
# usually plenty — mood transitions still feel responsive and the 30-track
# pool covers ~2 hours of music if Liquidsoap ever falls back to it.
AUTO_QUEUE_REFRESH_MINUTES=60

# Admin auth — gates /settings, /debug, /jingles, /restart-mixer, etc.
# REQUIRED in production: the controller exits at boot if either is missing
# (see controller/src/middleware/auth.js). Optional in dev, but recommended.
# `subwave setup` prompts for both and writes them here.
ADMIN_USER=admin
ADMIN_PASS=changeme

# News skill — RSS feed read by the news DJ skill
NEWS_FEED_URL=http://feeds.bbci.co.uk/news/rss.xml
NEWS_MAX_ITEMS=10

# Web-search skill — Tavily API key (https://tavily.com). When blank, the
# web-search skill stays inert and never fires.
# SEARCH_API_KEY=tvly-...
